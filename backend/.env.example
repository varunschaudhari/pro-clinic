# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=clinixindia

# ─────────────────────────────────────────
# JWT (use strong random strings in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_min_64_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────
# Cookies
# ─────────────────────────────────────────
COOKIE_SECRET=your_cookie_secret_here

# ─────────────────────────────────────────
# Frontend URL (CORS)
# ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────
# Disabled automatically in development (NODE_ENV=development)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ─────────────────────────────────────────
# Email (SMTP) — Nodemailer
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="ClinixIndia <noreply@clinixindia.com>"

# ─────────────────────────────────────────
# Cloudinary (file uploads — reports, logos)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────
# Razorpay (subscription billing)
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─────────────────────────────────────────
# MSG91 — SMS & WhatsApp notifications
# Sign up at https://msg91.com
# ─────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_authkey_here
MSG91_SENDER_ID=CLINIC

# WhatsApp Business — your MSG91 integrated number (with country code, no +)
MSG91_WA_INTEGRATED_NUMBER=91XXXXXXXXXX

# SMS Flow IDs (create templates in MSG91 dashboard → Campaigns → Flows)
# Each flow uses named variables: patient, doctor, date, time, token, status, test, report_no
MSG91_FLOW_APPT_CONFIRM=your_flow_id_here
MSG91_FLOW_APPT_REMINDER=your_flow_id_here
MSG91_FLOW_APPT_STATUS=your_flow_id_here
MSG91_FLOW_LAB_READY=your_flow_id_here

# WhatsApp template names (approved via Meta through MSG91 dashboard)
MSG91_WA_TPL_APPT_CONFIRM=appt_confirmation
MSG91_WA_TPL_APPT_REMINDER=appt_reminder
MSG91_WA_TPL_APPT_STATUS=appt_status_update
MSG91_WA_TPL_LAB_READY=lab_result_ready

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=info
